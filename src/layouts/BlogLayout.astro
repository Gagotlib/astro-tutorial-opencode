---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

export interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      <a href="/blog" class="text-purple-400 hover:text-purple-300 text-sm mb-4 inline-block">
        &larr; Back to blog
      </a>
      <h1 class="text-4xl font-bold mb-4">{entry.data.title}</h1>
      <div class="flex flex-wrap gap-2 text-sm text-gray-400 mb-4">
        <time datetime={entry.data.pubDate.toISOString()}>
          {entry.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        <span class="text-gray-600">|</span>
        <span>{entry.data.author}</span>
      </div>
      {entry.data.nextJsEquivalent && (
        <div class="bg-gray-800 border border-gray-700 rounded-lg p-3 mb-6 text-sm">
          <span class="text-gray-400">Next.js equivalent:</span>{" "}
          <span class="text-blue-400">{entry.data.nextJsEquivalent}</span>
        </div>
      )}
      <div class="flex gap-2">
        {entry.data.tags.map((tag) => (
          <span class="bg-gray-800 text-gray-300 px-2 py-1 rounded text-xs">{tag}</span>
        ))}
      </div>
    </header>
    <div class="prose prose-invert max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
