---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

export interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-3xl mx-auto">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": entry.data.title,
      "description": entry.data.description,
      "author": {
        "@type": "Person",
        "name": entry.data.author,
      },
      "datePublished": entry.data.pubDate.toISOString(),
    })} />
    <header class="mb-10">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition-colors mb-6 group">
        <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to blog
      </a>

      <div class="flex flex-wrap gap-2 mb-4">
        {entry.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        <span class="bg-gradient-to-r from-white via-white to-gray-300 bg-clip-text text-transparent">
          {entry.data.title}
        </span>
      </h1>
      <p class="text-gray-400 text-lg mb-6">{entry.data.description}</p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500 mb-6">
        <time datetime={entry.data.pubDate.toISOString()}>
          {entry.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        <span class="text-gray-700">/</span>
        <span>{entry.data.author}</span>
      </div>

      {entry.data.nextJsEquivalent && (
        <div class="glass rounded-xl p-4 text-sm border-l-2 border-l-astro-cyan">
          <span class="text-gray-400">Next.js equivalent:</span>{" "}
          <span class="text-astro-cyan font-medium">{entry.data.nextJsEquivalent}</span>
        </div>
      )}
    </header>
    <div class="article-content prose prose-invert max-w-none
      prose-headings:font-heading prose-headings:text-white prose-headings:tracking-tight
      prose-h2:text-3xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-gray-100 prose-p:leading-[1.75] prose-p:text-[15px]
      prose-strong:text-white prose-strong:font-semibold
      prose-a:text-astro-purple prose-a:no-underline hover:prose-a:underline prose-a:transition-all prose-a:duration-200
      prose-code:font-mono prose-code:text-astro-pink prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-[13px] prose-code:font-normal
      prose-pre:bg-deep-200 prose-pre:border prose-pre:border-white/5 prose-pre:rounded-xl prose-pre:shadow-lg
      prose-li:text-gray-300 prose-li:leading-[1.75]
      prose-hr:border-white/10
      prose-blockquote:border-l-astro-purple prose-blockquote:border-l-2 prose-blockquote:pl-5 prose-blockquote:py-2 prose-blockquote:pr-4 prose-blockquote:bg-white/[0.02] prose-blockquote:rounded-r-xl prose-blockquote:text-gray-300 prose-blockquote:italic prose-blockquote:not-italic
      prose-table:border-collapse prose-table:w-full
      prose-th:bg-white/[0.03] prose-th:border prose-th:border-white/5 prose-th:px-4 prose-th:py-2.5 prose-th:text-left prose-th:text-sm prose-th:text-gray-300 prose-th:font-medium
      prose-td:border prose-td:border-white/5 prose-td:px-4 prose-td:py-2.5 prose-td:text-sm prose-td:text-gray-300
      prose-tr:even:bg-white/[0.015]
      prose-ul:space-y-1.5
      prose-ol:space-y-1.5
      prose-li::marker:text-astro-purple/60
      prose-img:rounded-xl prose-img:border prose-img:border-white/5">
      <Content />
    </div>
  </article>
</BaseLayout>
