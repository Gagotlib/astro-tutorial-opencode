---
import BaseLayout from "../layouts/BaseLayout.astro";
import Counter from "../components/react/Counter";
import TodoList from "../components/react/TodoList";
import ThemeToggle from "../components/react/ThemeToggle";
import HydrationVisualizer from "../components/react/HydrationVisualizer";
import StaticComparison from "../components/react/StaticComparison";
import { getSession } from "../lib/auth";

const user = getSession(Astro.cookies);
---

<BaseLayout title="Dashboard" description="Interactive dashboard with Astro islands">
  <section class="mb-10">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div>
        <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-2">Interactive Dashboard</h1>
        {user ? (
          <p class="text-green-400 text-sm">
            Welcome back, <span class="font-semibold">{user.name}</span>!
            <a href="/api/logout" class="text-gray-500 hover:text-white ml-4 transition-colors">
              Logout &rarr;
            </a>
          </p>
        ) : (
          <p class="text-gray-400 text-sm">
            <a href="/login" class="text-astro-purple hover:text-astro-pink transition-colors">
              Login
            </a>{" "}
            to see authentication in action.
          </p>
        )}
      </div>
      <div class="flex items-center gap-2 text-xs text-gray-500">
        <span class="w-2 h-2 rounded-full bg-green-400" />
        Islands active
      </div>
    </div>
    <p class="text-gray-500 text-sm mt-3">
      This page demonstrates multiple interactive islands working together. Each
      React component is independently hydrated.
    </p>
  </section>

  <section class="mb-14">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
      <h2 class="font-heading text-xl font-bold text-white">Active Islands</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      <Counter client:load initial={0} />
      <ThemeToggle client:load />
      <HydrationVisualizer client:load />
    </div>
  </section>

  <section class="mb-14">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-cyan/30 to-transparent" />
      <h2 class="font-heading text-xl font-bold text-white">Todo Manager</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-cyan/30 to-transparent" />
    </div>
    <div class="max-w-lg">
      <TodoList client:load />
    </div>
  </section>

  <section class="mb-14">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-pink/30 to-transparent" />
      <h2 class="font-heading text-xl font-bold text-white">Performance Insights</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-pink/30 to-transparent" />
    </div>
    <p class="text-gray-400 text-sm mb-6 text-center max-w-xl mx-auto">
      This dashboard loads multiple React islands, but total JS is still much
      smaller than a traditional React SPA because the rest of the page is static HTML.
    </p>
    <StaticComparison client:load />
  </section>

  <section class="glass rounded-xl p-8">
    <h2 class="font-heading text-xl font-bold text-white mb-6 text-center">Astro Fundamentals Reference</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <a href="/blog/01-astro-vs-nextjs" class="group glass rounded-lg p-4 glass-hover">
        <h3 class="font-heading font-semibold text-white mb-1 group-hover:text-astro-purple transition-colors">Astro vs Next.js</h3>
        <p class="text-sm text-gray-400">Framework comparison</p>
      </a>
      <a href="/blog/02-islands-architecture" class="group glass rounded-lg p-4 glass-hover">
        <h3 class="font-heading font-semibold text-white mb-1 group-hover:text-astro-purple transition-colors">Islands Architecture</h3>
        <p class="text-sm text-gray-400">Hydration model explained</p>
      </a>
      <a href="/blog/03-ssg-vs-ssr" class="group glass rounded-lg p-4 glass-hover">
        <h3 class="font-heading font-semibold text-white mb-1 group-hover:text-astro-purple transition-colors">SSG vs SSR</h3>
        <p class="text-sm text-gray-400">Rendering strategies</p>
      </a>
      <a href="/blog/04-content-collections" class="group glass rounded-lg p-4 glass-hover">
        <h3 class="font-heading font-semibold text-white mb-1 group-hover:text-astro-purple transition-colors">Content Collections</h3>
        <p class="text-sm text-gray-400">Markdown management</p>
      </a>
    </div>
  </section>
</BaseLayout>
