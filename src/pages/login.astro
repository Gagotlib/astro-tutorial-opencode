---
import BaseLayout from "../layouts/BaseLayout.astro";
import LoginForm from "../components/react/LoginForm";
import { getSession } from "../lib/auth";

const user = getSession(Astro.cookies);
---

<BaseLayout title="Login" description="Demo login page for authentication tutorial">
  <section class="max-w-md mx-auto pt-4 sm:pt-8">
    {
      user ? (
        <div class="glass rounded-2xl p-8 text-center">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-green-400 to-emerald-500 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="font-heading text-2xl font-bold mb-2 text-white">Already Logged In</h2>
          <p class="text-gray-400 mb-6">You are logged in as <span class="text-white font-semibold">{user.name}</span>.</p>
          <div class="flex gap-3 justify-center">
            <a href="/dashboard" class="btn-gradient px-5 py-2 rounded-xl text-sm text-white">
              Go to Dashboard
            </a>
            <a href="/api/logout" class="btn-ghost px-5 py-2 rounded-xl text-sm text-gray-300">
              Logout
            </a>
          </div>
        </div>
      ) : (
        <LoginForm client:load returnUrl="/dashboard" />
      )
    }
  </section>

  <section class="mt-14 max-w-2xl mx-auto">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
      <h2 class="font-heading text-xl font-bold text-white">How Auth Works in Astro</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
    </div>
    <div class="glass rounded-xl p-6 space-y-5">
      <div class="flex gap-4">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-astro-purple to-astro-pink flex items-center justify-center shrink-0 text-sm font-bold text-white">1</div>
        <div>
          <h3 class="font-heading font-semibold text-white mb-1">Server-Side Session Check</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            In Astro, you check cookies in the frontmatter (<code class="text-astro-cyan font-mono text-xs">---</code>) of the page. This runs on the server, so no session data reaches the client.
          </p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-astro-purple to-astro-pink flex items-center justify-center shrink-0 text-sm font-bold text-white">2</div>
        <div>
          <h3 class="font-heading font-semibold text-white mb-1">API Endpoint for Login</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            The login form POSTs to <code class="text-astro-cyan font-mono text-xs">/api/login</code>, which validates credentials and sets a session cookie.
          </p>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-astro-purple to-astro-pink flex items-center justify-center shrink-0 text-sm font-bold text-white">3</div>
        <div>
          <h3 class="font-heading font-semibold text-white mb-1">Comparison with Next.js</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Next.js typically uses <code class="text-astro-cyan font-mono text-xs">next-auth</code> or middleware for auth. Astro's approach is simpler because pages are static by default — you opt into SSR only for pages that need session checks.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
