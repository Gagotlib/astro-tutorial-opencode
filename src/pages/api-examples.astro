---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";

const title = "API Calls and Server Endpoints";
const description = "Learn how API endpoints work in Astro compared to Next.js Route Handlers";
---

<BaseLayout title={title} description={description}>
  <section class="text-center mb-12 pt-4 sm:pt-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-astro-purple/10 text-astro-purple border border-astro-purple/20 mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-astro-purple" />
      Server Endpoints
    </div>
    <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">
      <span class="bg-gradient-to-r from-astro-purple via-astro-pink to-astro-cyan bg-clip-text text-transparent">API Calls & Server Endpoints</span>
    </h1>
    <p class="text-gray-400 max-w-xl mx-auto">
      Astro API endpoints are like Next.js Route Handlers. They live in
      <code class="text-astro-cyan font-mono text-xs mx-1">src/pages/api/*.ts</code> and export
      <code class="text-astro-cyan font-mono text-xs">GET</code>, <code class="text-astro-cyan font-mono text-xs">POST</code>,
      etc. handler functions.
    </p>
  </section>

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="w-3 h-3 rounded-full bg-green-400" />
      <h2 class="font-heading text-xl font-bold text-white">Build-Time Data Fetching <span class="text-sm font-normal text-gray-400">(SSG)</span></h2>
    </div>
    <p class="text-gray-400 mb-4 text-sm">
      In Astro, you can fetch data directly in the frontmatter of any page. This
      runs at build time for static pages.
    </p>
    <div class="glass rounded-xl p-6">
      <pre class="code-block p-4 mb-4 overflow-x-auto"><span class="text-gray-500">// src/pages/example.astro</span>
---
<span class="text-gray-500">// This runs at build time, not on every request</span>
const response = await fetch(<span class="text-astro-cyan">"https://api.example.com/data"</span>);
const data = await response.json();
---
&lt;div&gt;<span class="text-yellow-300">&#123;data.title&#125;</span>&lt;/div&gt;</pre>
      <p class="text-sm text-gray-400">
        In Next.js, this is equivalent to fetching in a Server Component or using
        <code class="text-astro-cyan font-mono text-xs">getStaticProps</code> in Pages Router.
      </p>
    </div>
  </section>

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="w-3 h-3 rounded-full bg-yellow-400" />
      <h2 class="font-heading text-xl font-bold text-white">Server-Side Data Fetching <span class="text-sm font-normal text-gray-400">(SSR)</span></h2>
    </div>
    <p class="text-gray-400 mb-4 text-sm">
      Use <code class="text-astro-cyan font-mono text-xs">export const prerender = false</code> to
      render data on every request.
    </p>
    <div class="glass rounded-xl p-6">
      <pre class="code-block p-4 mb-4 overflow-x-auto">---
export const prerender = <span class="text-yellow-300">false</span>;
const res = await fetch(<span class="text-astro-cyan">"https://api.example.com/data"</span>);
const data = await res.json();
---</pre>
      <p class="text-sm text-gray-400">
        In Next.js, this is equivalent to a dynamic Server Component or
        <code class="text-astro-cyan font-mono text-xs">getServerSideProps</code>.
      </p>
    </div>
  </section>

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
      <h2 class="font-heading text-xl font-bold text-white">API Endpoints</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
    </div>
    <p class="text-gray-400 mb-6 text-sm text-center">
      Astro API endpoints work like Next.js Route Handlers. Here is the comparison:
    </p>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="glass rounded-xl p-6">
        <h3 class="font-heading font-semibold text-white mb-3">Astro</h3>
        <pre class="code-block p-4 overflow-x-auto"><span class="text-gray-500">// src/pages/api/hello.ts</span>
import type <span class="text-yellow-300">&#123; APIRoute &#125;</span> from <span class="text-astro-cyan">"astro"</span>;

export const prerender = <span class="text-yellow-300">false</span>;

export const GET: APIRoute = async (<span class="text-gray-400">&#123; request, cookies, redirect &#125;</span>) => <span class="text-yellow-300">&#123;</span>
  return new Response(JSON.stringify(<span class="text-yellow-300">&#123; message: "Hello" &#125;</span>), <span class="text-yellow-300">&#123;</span>
    status: 200,
    headers: <span class="text-yellow-300">&#123;</span> <span class="text-astro-cyan">"Content-Type"</span>: <span class="text-astro-cyan">"application/json"</span> <span class="text-yellow-300">&#125;</span>,
  <span class="text-yellow-300">&#125;</span>);
<span class="text-yellow-300">&#125;</span>;</pre>
      </div>
      <div class="glass rounded-xl p-6">
        <h3 class="font-heading font-semibold text-white mb-3">Next.js</h3>
        <pre class="code-block p-4 overflow-x-auto"><span class="text-gray-500">// app/api/hello/route.ts</span>
import <span class="text-yellow-300">&#123; NextResponse &#125;</span> from <span class="text-astro-cyan">"next/server"</span>;

export async function GET() <span class="text-yellow-300">&#123;</span>
  return NextResponse.json(<span class="text-yellow-300">&#123; message: "Hello" &#125;</span>);
<span class="text-yellow-300">&#125;</span>;</pre>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <div class="flex items-center gap-3 mb-4">
      <span class="w-3 h-3 rounded-full bg-cyan-400" />
      <h2 class="font-heading text-xl font-bold text-white">Try the API Endpoints</h2>
    </div>
    <p class="text-gray-400 mb-6 text-sm">
      These endpoints are live on this server. Click to test them:
    </p>
    <div class="grid md:grid-cols-3 gap-4">
      <a
        href="/api/hello"
        target="_blank"
        class="glass rounded-xl p-5 hover:border-astro-purple/40 transition-all text-center hover:-translate-y-0.5"
      >
        <div class="text-astro-purple font-semibold mb-1">GET /api/hello</div>
        <div class="text-xs text-gray-500">Returns JSON greeting</div>
      </a>
      <a
        href="/api/session"
        target="_blank"
        class="glass rounded-xl p-5 hover:border-astro-purple/40 transition-all text-center hover:-translate-y-0.5"
      >
        <div class="text-astro-purple font-semibold mb-1">GET /api/session</div>
        <div class="text-xs text-gray-500">Returns session status</div>
      </a>
      <div class="glass rounded-xl p-5 text-center opacity-70">
        <div class="text-astro-purple font-semibold mb-1">POST /api/login</div>
        <div class="text-xs text-gray-500">Use LoginForm component</div>
      </div>
    </div>
  </section>

  <section class="glass rounded-xl p-8 glow">
    <h2 class="font-heading text-xl font-bold text-white mb-6 text-center">Key Differences from Next.js</h2>
    <ul class="space-y-4 text-sm text-gray-300 max-w-xl mx-auto">
      <li class="flex gap-3 items-start">
        <span class="w-5 h-5 rounded-full bg-astro-purple/20 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-astro-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
        </span>
        <strong>Runtime:</strong> Astro endpoints run on the server (Node.js, Deno, or Edge).
        Next.js Route Handlers run on Edge or Node.js.
      </li>
      <li class="flex gap-3 items-start">
        <span class="w-5 h-5 rounded-full bg-astro-purple/20 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-astro-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
        </span>
        <strong>SSR opt-in:</strong> In Astro, you need <code class="text-astro-cyan font-mono text-xs">prerender = false</code>. In Next.js App Router, routes are dynamic by default.
      </li>
      <li class="flex gap-3 items-start">
        <span class="w-5 h-5 rounded-full bg-astro-purple/20 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-astro-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
        </span>
        <strong>Response format:</strong> Astro uses the Web Fetch API (<code class="text-astro-cyan font-mono text-xs">Response</code>, <code class="text-astro-cyan font-mono text-xs">Request</code>). Next.js provides <code class="text-astro-cyan font-mono text-xs">NextResponse</code> helpers.
      </li>
      <li class="flex gap-3 items-start">
        <span class="w-5 h-5 rounded-full bg-astro-purple/20 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-3 h-3 text-astro-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
        </span>
        <strong>Cookies:</strong> Astro provides <code class="text-astro-cyan font-mono text-xs">Astro.cookies</code> in pages and <code class="text-astro-cyan font-mono text-xs">cookies</code> in API routes. Next.js uses <code class="text-astro-cyan font-mono text-xs">cookies()</code> from <code class="text-astro-cyan font-mono text-xs">next/headers</code>.
      </li>
    </ul>
  </section>
</BaseLayout>