---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Counter from "../components/react/Counter";
import TodoList from "../components/react/TodoList";
import StaticComparison from "../components/react/StaticComparison";
---

<BaseLayout title="Home" description="Learn Astro from Next.js perspective">
  <section class="text-center mb-20 pt-8 sm:pt-16">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-astro-purple/10 text-astro-purple border border-astro-purple/20 mb-6 animate-slide-up-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-astro-purple animate-pulse" />
      From Next.js to Astro
    </div>
    <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6 animate-slide-up">
      <span class="bg-gradient-to-r from-astro-purple via-astro-pink to-astro-cyan bg-200 animate-gradient-x bg-clip-text text-transparent">
        From Next.js to Astro
      </span>
    </h1>
    <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed animate-fade-in">
      A practical guide for React and Next.js developers to understand Astro's
      philosophy, architecture, and performance benefits.
    </p>
    <div class="flex items-center justify-center gap-4 mt-8 animate-fade-in">
      <a href="#interactive" class="btn-gradient px-6 py-2.5 rounded-xl text-sm text-white">
        Try Interactive Examples
      </a>
      <a href="/blog" class="btn-ghost px-6 py-2.5 rounded-xl text-sm text-gray-300">
        Read the Blog
      </a>
    </div>
  </section>

  <section class="mb-20">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
      <h2 class="font-heading text-2xl font-bold text-white">What Makes Astro Different?</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-purple/30 to-transparent" />
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      <a href="/blog/01-astro-vs-nextjs" class="group glass rounded-xl p-6 glass-hover">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-astro-purple to-astro-pink flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white text-lg font-bold">1</span>
        </div>
        <h3 class="font-heading font-semibold text-white mb-2 group-hover:text-astro-purple transition-colors">Astro vs Next.js</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Core philosophy, trade-offs, and when to use each framework.
        </p>
      </a>
      <a href="/blog/02-islands-architecture" class="group glass rounded-xl p-6 glass-hover">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-astro-purple to-astro-pink flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white text-lg font-bold">2</span>
        </div>
        <h3 class="font-heading font-semibold text-white mb-2 group-hover:text-astro-purple transition-colors">Islands Architecture</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          How Astro's partial hydration delivers better performance.
        </p>
      </a>
      <a href="/blog/03-ssg-vs-ssr" class="group glass rounded-xl p-6 glass-hover">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-astro-purple to-astro-pink flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white text-lg font-bold">3</span>
        </div>
        <h3 class="font-heading font-semibold text-white mb-2 group-hover:text-astro-purple transition-colors">SSG vs SSR</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Static generation vs server rendering in Astro and Next.js.
        </p>
      </a>
      <a href="/blog/04-content-collections" class="group glass rounded-xl p-6 glass-hover">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-astro-purple to-astro-pink flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-white text-lg font-bold">4</span>
        </div>
        <h3 class="font-heading font-semibold text-white mb-2 group-hover:text-astro-purple transition-colors">Content Collections</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Built-in Markdown management with schema validation.
        </p>
      </a>
    </div>
  </section>

  <section class="mb-20" id="interactive">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-cyan/30 to-transparent" />
      <h2 class="font-heading text-2xl font-bold text-white">Interactive Islands</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-cyan/30 to-transparent" />
    </div>
    <p class="text-gray-400 mb-8 text-center max-w-xl mx-auto">
      These React components only ship JavaScript because of their{" "}
      <code class="text-astro-cyan font-mono text-sm">client:load</code> directive.
    </p>
    <div class="grid md:grid-cols-2 gap-6">
      <Counter client:load initial={0} />
      <TodoList client:load />
    </div>
  </section>

  <section class="mb-20">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-pink/30 to-transparent" />
      <h2 class="font-heading text-2xl font-bold text-white">Performance Comparison</h2>
      <div class="h-px flex-1 bg-gradient-to-r from-transparent via-astro-pink/30 to-transparent" />
    </div>
    <p class="text-gray-400 mb-8 text-center max-w-xl mx-auto">
      See how different rendering approaches affect bundle size and hydration.
    </p>
    <StaticComparison client:load />
  </section>
</BaseLayout>
